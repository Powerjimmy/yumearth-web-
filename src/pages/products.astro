---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Products" description="The full YumEarth EU range — organic lollipops and soft candy. No artificial anything.">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "YumEarth EU — Product Catalogue",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "item": {
          "@type": "Product",
          "name": "Lollipops",
          "description": "Organic lollipops — Classic Assorted, Juicy Pops, Strawberry Pops, Vitamin C Pops. Real fruit flavor, zero artificial dyes.",
          "image": "https://yumearth.eu/images/products/lollipops.webp",
          "brand": { "@type": "Brand", "name": "YumEarth" }
        }
      },
      {
        "@type": "ListItem",
        "position": 2,
        "item": {
          "@type": "Product",
          "name": "Soft Candy",
          "description": "Organic soft candy — Sour Beans, Fruit Snacks, Gummy Bears, Giggles. Allergen-friendly and vegan.",
          "image": "https://yumearth.eu/images/products/fruit-snacks.webp",
          "brand": { "@type": "Brand", "name": "YumEarth" }
        }
      }
    ]
  })} />
  <Nav />
  <main class="pt-32">

    <!-- Header -->
    <section class="max-w-7xl mx-auto px-6 pb-16">
      <div class="max-w-2xl">
        <h1 class="text-5xl md:text-6xl mb-4 font-black" style="font-family:'Nunito',sans-serif; letter-spacing:-0.03em; line-height:0.95;">
          Products
        </h1>
      </div>
    </section>

    <!-- Certification badges -->
    <section class="max-w-7xl mx-auto px-6 pb-12">
      <img
        src="/images/img/icons-allergy.friendly.webp"
        alt="USDA Organic, Gluten Free, Vegan, No Artificial Colors, No Artificial Flavors, Allergen Friendly"
        style="width:100%; max-width:860px; height:auto;"
      />
    </section>

    <!-- 2 Category tiles -->
    <section class="max-w-7xl mx-auto px-6 pb-24">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <!-- Lollipops -->
        <a
          href="/lollipops"
          class="card-lift group rounded-3xl overflow-hidden flex flex-col"
          style="background:#FFF0F2; min-height:480px;"
        >
          <div class="flex-1 flex items-center justify-center p-12">
            <img
              src="/images/products/lollipops.webp"
              alt="YumEarth Organic Lollipops"
              class="w-48 h-48 md:w-64 md:h-64 object-contain transition-transform duration-500 group-hover:scale-105"
              style="filter:drop-shadow(0 20px 40px rgba(215,0,45,0.2));"
            />
          </div>
          <div class="p-8 pt-0">
            <h2 class="font-black mb-2" style="font-family:'Nunito',sans-serif; font-weight:900; font-size:clamp(2rem,4vw,2.8rem); line-height:0.95; letter-spacing:-0.03em;">
              Lollipops
            </h2>
          </div>
        </a>

        <!-- Soft Candy -->
        <a
          href="/soft-candy"
          class="card-lift group rounded-3xl overflow-hidden flex flex-col"
          style="background:#EFF8E6; min-height:480px;"
        >
          <div class="flex-1 flex items-center justify-center p-12">
            <img
              src="/images/products/fruit-snacks.webp"
              alt="YumEarth Soft Candy"
              class="w-48 h-48 md:w-64 md:h-64 object-contain transition-transform duration-500 group-hover:scale-105"
              style="filter:drop-shadow(0 20px 40px rgba(74,145,0,0.2));"
            />
          </div>
          <div class="p-8 pt-0">
            <h2 class="font-black mb-2" style="font-family:'Nunito',sans-serif; font-weight:900; font-size:clamp(2rem,4vw,2.8rem); line-height:0.95; letter-spacing:-0.03em;">
              Soft Candy
            </h2>
          </div>
        </a>

      </div>
    </section>

  </main>
  <Footer />
</Layout>
