---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const products = [
  {
    name: 'Classic Assorted Lollipops',
    pack: '14 u',
    desc: '',
    flavors: ['Pomegranate Pucker', 'Strawberry Smash', 'Very Very Cherry', 'Perfectly Peach'],
    image: '/images/products/bolsa-lollipops-14.webp',
    hoverImage: '/images/products/3d-1024-back-yumearth-2.webp',
    fallback: '/images/products/lollipops.webp',
    color: '#FFF0F2',
    accent: '#D7002D',
    badge: '',
  },
  {
    name: 'Juicy Lollipops',
    pack: '14 u',
    desc: '',
    flavors: ['Sour Apple Tart', 'Very Very Cherry', 'Googly Grape'],
    image: '/images/products/bolsa-juicy-pops.webp',
    hoverImage: '/images/products/3d-1026-back-organic-juicy-2.webp',
    fallback: '/images/products/lollipops.webp',
    color: '#FFF5E0',
    accent: '#FF7803',
    badge: '',
  },
  {
    name: 'Vitamin C Lollipops',
    pack: '14 u',
    desc: '',
    flavors: ['Strawberry Smash', 'Very Very Cherry', 'Razzmatazz Berry'],
    image: '/images/products/bolsa-vitamin-c.webp',
    hoverImage: '/images/products/3d-1669-back-vitaminC-2.webp',
    fallback: '/images/products/vitamin-lollipops.webp',
    color: '#FFF5E6',
    accent: '#FF7803',
    badge: '',
  },
  {
    name: 'Strawberry Lollipops',
    pack: '14 u',
    desc: '',
    flavors: ['Strawberry Smash'],
    image: '/images/products/bolsas/bolsa-lollipops-fresa-front-14.webp',
    hoverImage: '/images/products/bolsas/bolsa-lollipops-fresa-back-14.webp',
    fallback: '/images/products/lollipops.webp',
    color: '#FFF0F2',
    accent: '#D7002D',
    badge: '',
  },
  {
    name: 'Assorted 40 Lollipops',
    pack: '40 u',
    desc: '',
    flavors: ['Pomegranate Pucker', 'Strawberry Smash', 'Very Very Cherry', 'Perfectly Peach', 'And more'],
    image: '/images/products/bolsa-lollipops-40.webp',
    hoverImage: '/images/products/3d-1025-back-yumearth-2.webp',
    fallback: '/images/products/lollipops.webp',
    color: '#F0FFF0',
    accent: '#4a9100',
    badge: '',
  },
  {
    name: '100-unit Assorted',
    pack: '100 u',
    desc: '',
    flavors: ['Pomegranate Pucker', 'Strawberry Smash', 'Very Very Cherry', 'Perfectly Peach', 'Googly Grape', 'And more'],
    image: '/images/img/3D-1008-Organic-Assorted-Lollipops_100_pops.webp',
    hoverImage: null,
    fallback: '/images/products/lollipops.webp',
    color: '#EBF5FF',
    accent: '#0066CC',
    badge: '',
  },
];

// Individual lollipop wrapper images
const wrappers = [
  { src: '/images/products/lollipops/pomegranate-pucker.webp', hover: '/images/products/lollipops-unidades/PopWrappers_Pomegranate.png', label: 'Pomegranate Pucker', color: '#8b1a4a' },
  { src: '/images/products/lollipops/strawberry-smash.webp', hover: '/images/products/lollipops-unidades/PopWrappers_Strawberry.png', label: 'Strawberry Smash', color: '#D7002D' },
  { src: '/images/products/lollipops/very-very-cherry.webp', hover: '/images/products/lollipops-unidades/PopWrappers_Cherry.png', label: 'Very Very Cherry', color: '#c0001a' },
  { src: '/images/products/lollipops/perfectly-peach.webp', hover: '/images/products/lollipops-unidades/PopWrappers_Peach.png', label: 'Perfectly Peach', color: '#e87c2a' },
  { src: '/images/products/lollipops/googly-grape.webp', hover: '/images/products/lollipops-unidades/PopWrappers_Grape.png', label: 'Googly Grape', color: '#6b2fa0' },
  { src: '/images/products/lollipops/razzmatazz-berry.webp', hover: '/images/products/lollipops-unidades/PopWrappers_Blueberry.png', label: 'Razzmatazz Berry', color: '#c21460' },
  { src: '/images/products/lollipops/watermelon.webp', hover: '/images/products/lollipops-unidades/PopWrappers_Watermelon.png', label: 'Watermelon', color: '#2d9e4a' },
  { src: '/images/products/lollipops/mango-tango.webp', hover: '/images/products/lollipops-unidades/PopWrappers_Mango.png', label: 'Mango Tango', color: '#e8920a' },
];
---

<Layout title="Lollipops" description="YumEarth EU organic lollipops — Classic Assorted, Juicy Pops, Vitamin C Pops, 100-unit bulk. Real fruit, zero artificial anything.">
  <Nav />
  <main class="pt-32">

    <!-- Header -->
    <section class="max-w-7xl mx-auto px-6 pb-16">
      <div class="flex items-center gap-3 mb-6">
        <a href="/products" class="text-sm font-bold hover:text-teal transition-colors" style="color:var(--color-ink-muted);">
          ← Products
        </a>
      </div>
      <div class="max-w-3xl">
        <h1 class="font-black mb-4" style="font-family:'Nunito',sans-serif; font-size:clamp(2.5rem,6vw,4.5rem); line-height:0.95; letter-spacing:-0.03em;">
          Lollipops
        </h1>
      </div>
      <div class="mt-4">
        <img
          src="/images/img/icons-allergy.friendly.webp"
          alt="USDA Organic, Gluten Free, Vegan, No Artificial Colors, No Artificial Flavors, Allergen Friendly"
          style="width:100%; max-width:860px; height:auto;"
          loading="eager"
        />
      </div>
    </section>

    <!-- Individual flavor wrappers -->
    <section class="pb-16" style="background:var(--color-surface);">
      <div class="max-w-7xl mx-auto px-6 py-12">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
          {wrappers.map(w => (
            <div class="flex flex-col items-center gap-2">
              <div class="flavor-swap w-full aspect-square rounded-2xl flex items-center justify-center p-3"
                style="background:white; box-shadow:0 2px 12px rgba(0,0,0,0.08); position:relative; overflow:hidden;">
                <img
                  src={w.src}
                  alt={w.label}
                  class="flavor-base w-full h-full object-contain"
                  style="filter:drop-shadow(0 4px 8px rgba(0,0,0,0.15)); transition: opacity 0.3s var(--ease-out), transform 0.3s var(--ease-out);"
                  loading="lazy"
                />
                <img
                  src={w.hover}
                  alt={`${w.label} individual wrapper`}
                  class="flavor-hover absolute inset-0 w-full h-full object-contain p-3"
                  style="filter:drop-shadow(0 4px 8px rgba(0,0,0,0.2)); opacity:0; transform:scale(0.9); transition: opacity 0.3s var(--ease-out), transform 0.3s var(--ease-out);"
                  loading="lazy"
                />
              </div>
              <p class="text-xs font-bold text-center leading-tight" style={`color:${w.color};`}>{w.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Product bags -->
    <section class="max-w-7xl mx-auto px-6 pb-24 pt-8">
      <div class="space-y-6">
        {products.map((p, i) => (
          <div
            class="card-lift grid grid-cols-1 md:grid-cols-2 rounded-3xl overflow-hidden"
            style={`background:${p.color};`}
          >
            <div class={`flex items-center justify-center p-6 md:p-10 md:min-h-[300px] ${i % 2 === 1 ? 'md:order-2' : ''}`}>
              {p.hoverImage ? (
                <button
                  class="product-swap relative w-48 h-48 md:w-64 md:h-64 cursor-zoom-in"
                  data-lightbox-front={p.image}
                  data-lightbox-back={p.hoverImage}
                  data-lightbox-name={p.name}
                  aria-label={`View ${p.name} front and back`}
                  type="button"
                >
                  <img
                    src={p.image}
                    alt={p.name}
                    class="img-base"
                    style="filter:drop-shadow(0 20px 40px rgba(0,0,0,0.18)); transition: opacity 0.4s var(--ease-out), transform 0.4s var(--ease-out);"
                    loading="lazy"
                    onerror={`this.src='${p.fallback}'`}
                  />
                  <img
                    src={p.hoverImage}
                    alt={`${p.name} back of pack`}
                    class="img-hover"
                    style="filter:drop-shadow(0 20px 40px rgba(0,0,0,0.25)); opacity:0; transform:scale(0.95); transition: opacity 0.4s var(--ease-out), transform 0.4s var(--ease-out);"
                    loading="lazy"
                  />
                </button>
              ) : (
                <button
                  class="product-single relative w-48 h-48 md:w-64 md:h-64 cursor-zoom-in"
                  data-lightbox-front={p.image}
                  data-lightbox-name={p.name}
                  aria-label={`Zoom ${p.name}`}
                  type="button"
                >
                  <img
                    src={p.image}
                    alt={p.name}
                    class="w-full h-full object-contain"
                    style="filter:drop-shadow(0 20px 40px rgba(0,0,0,0.18)); transition: transform 0.3s var(--ease-out);"
                    loading="lazy"
                    onerror={`this.src='${p.fallback}'`}
                  />
                </button>
              )}
            </div>
            <div class={`p-10 flex flex-col justify-center ${i % 2 === 1 ? 'md:order-1' : ''}`}>
              <p class="text-xs font-black uppercase tracking-widest mb-2" style={`color:${p.accent};`}>{p.badge}</p>
              <h2 class="font-black mb-1" style={`font-family:'Nunito',sans-serif; font-size:clamp(1.6rem,3vw,2.4rem); line-height:0.95; letter-spacing:-0.02em;`}>
                {p.name}
              </h2>
              <p class="text-xs font-bold mb-4 uppercase tracking-widest" style="color:rgba(0,0,0,0.5);">{p.pack}</p>
              <p class="text-base mb-6" style="color:rgba(0,0,0,0.65); line-height:1.65; max-width:380px;">{p.desc}</p>
              <div class="flex flex-wrap gap-2">
                {p.flavors.map(f => (
                  <span class="text-xs font-bold px-3 py-1.5 rounded-full" style="background:rgba(255,255,255,0.8); color:rgba(0,0,0,0.65);">
                    {f}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>


  </main>
  <Footer />
</Layout>

<!-- Lightbox -->
<div id="lightbox" role="dialog" aria-modal="true" aria-label="Product image zoom" style="display:none; position:fixed; inset:0; z-index:9999; background:rgba(0,0,0,0.88); cursor:zoom-out; align-items:center; justify-content:center; padding:24px;">
  <div class="lightbox-inner">
    <img id="lightbox-img-front" src="" alt="" style="border-radius:16px; filter:drop-shadow(0 24px 48px rgba(0,0,0,0.5));" />
    <img id="lightbox-img-back" src="" alt="" style="border-radius:16px; filter:drop-shadow(0 24px 48px rgba(0,0,0,0.5));" />
  </div>
  <button id="lightbox-close" aria-label="Close" style="position:absolute; top:20px; right:24px; background:rgba(255,255,255,0.12); border:none; color:white; width:40px; height:40px; border-radius:50%; cursor:pointer; font-size:18px; display:flex; align-items:center; justify-content:center; transition:background 0.2s;">✕</button>
</div>

<script>
  const lb = document.getElementById('lightbox')!;
  const imgFront = document.getElementById('lightbox-img-front') as HTMLImageElement;
  const imgBack = document.getElementById('lightbox-img-back') as HTMLImageElement;
  const closeBtn = document.getElementById('lightbox-close')!;
  let prevFocus: HTMLElement | null = null;

  function openLightbox(front: string, back: string | null, name: string) {
    prevFocus = document.activeElement as HTMLElement;
    imgFront.src = front;
    imgFront.alt = name;
    if (back) {
      imgBack.src = back;
      imgBack.alt = `${name} back of pack`;
      imgBack.style.display = '';
    } else {
      imgBack.src = '';
      imgBack.style.display = 'none';
    }
    lb.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }

  function closeLightbox() {
    lb.style.display = 'none';
    document.body.style.overflow = '';
    prevFocus?.focus();
  }

  // Event delegation — all lightbox triggers
  document.addEventListener('click', (e) => {
    const trigger = (e.target as HTMLElement).closest<HTMLElement>('[data-lightbox-front]');
    if (trigger) {
      const front = trigger.dataset.lightboxFront!;
      const back = trigger.dataset.lightboxBack ?? null;
      const name = trigger.dataset.lightboxName ?? '';
      openLightbox(front, back, name);
      return;
    }
    if (e.target === lb || ((e.target as HTMLElement).closest('.lightbox-inner') === null && lb.style.display === 'flex')) {
      closeLightbox();
    }
  });

  closeBtn.addEventListener('click', closeLightbox);

  // Focus trap inside lightbox
  lb.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') { closeLightbox(); return; }
    if (e.key !== 'Tab') return;
    const focusable = lb.querySelectorAll<HTMLElement>('button, [href], input, [tabindex]:not([tabindex="-1"])');
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (e.shiftKey ? document.activeElement === first : document.activeElement === last) {
      e.preventDefault();
      (e.shiftKey ? last : first).focus();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && lb.style.display === 'flex') closeLightbox();
  });

  // Touch toggle for flavor swap cards
  document.querySelectorAll<HTMLElement>('.flavor-swap').forEach(card => {
    card.addEventListener('click', () => {
      card.classList.toggle('touch-flipped');
    });
  });
</script>

<style>
  /* Product hover swap — height-based sizing so both images appear identical scale */
  .product-swap .img-base,
  .product-swap .img-hover {
    position: absolute;
    inset: 0;
    margin: auto;
    height: 82%;
    width: auto;
    max-width: 82%;
    object-fit: contain;
  }
  @media (hover: hover) and (pointer: fine) {
    .product-swap:hover .img-base { opacity: 0; transform: scale(0.95); }
    .product-swap:hover .img-hover { opacity: 1 !important; transform: scale(1) !important; }
  }
  .product-swap:active { transform: scale(0.97); }

  /* Flavor hover swap */
  .flavor-swap { cursor: pointer; transition: transform 0.25s var(--ease-out), box-shadow 0.25s var(--ease-out); }
  @media (hover: hover) and (pointer: fine) {
    .flavor-swap:hover .flavor-base { opacity: 0; transform: scale(0.9); }
    .flavor-swap:hover .flavor-hover { opacity: 1 !important; transform: scale(1) !important; }
    .flavor-swap:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.12) !important; }
  }
  /* Touch tap-to-flip */
  .flavor-swap.touch-flipped .flavor-base { opacity: 0; transform: scale(0.9); }
  .flavor-swap.touch-flipped .flavor-hover { opacity: 1 !important; transform: scale(1) !important; }
  .flavor-swap:active { transform: scale(0.97) !important; }

  /* PLV button */
  .plv-btn { transition: background-color 0.18s var(--ease-out), transform 0.18s var(--ease-out), box-shadow 0.18s var(--ease-out); }
  .plv-btn:hover { background-color: #e09510 !important; transform: translateY(-2px); box-shadow: 0 8px 24px rgba(200,134,10,0.35); }
  .plv-btn:active { transform: translateY(1px) scale(0.97); box-shadow: none; }

  /* Single-image product zoom */
  .product-single { background: none; border: none; padding: 0; }
  .product-single:hover img { transform: scale(1.04); }
  .product-single:active { transform: scale(0.97); }

  /* Display zoom */
  .display-zoom { background: none; border: none; padding: 0; display: block; }
  .display-zoom:hover img { transform: scale(1.03); }
  .display-zoom:active { transform: scale(0.98); }

  /* Lightbox inner layout */
  .lightbox-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 32px;
    max-width: 100%;
  }
  .lightbox-inner img {
    height: 65vh;
    width: auto;
    max-width: 44vw;
    object-fit: contain;
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .lightbox-inner { flex-direction: column; gap: 16px; }
    .lightbox-inner img { height: 36vh; width: auto; max-width: 85vw; }
  }

  @media (prefers-reduced-motion: reduce) {
    .product-swap *, .flavor-swap *, .plv-btn { transition-duration: 0.01ms !important; }
  }
</style>
