---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const posts = [
  {
    slug: 'why-no-artificial-dyes',
    title: 'Why We Said No to Artificial Dyes — and What We Use Instead',
    date: 'June 2025',
    category: 'Ingredients',
    excerpt: "Most candy gets its color from petroleum-derived dyes. We decided early on that wasn't good enough. Here's how we do it differently.",
    body: [
      {
        type: 'intro',
        text: "Most candy gets its color from petroleum-derived dyes: Red 40, Yellow 5, Blue 1. They're cheap, stable, and vivid. They're also made from crude oil byproducts, and several have been linked to behavioral issues in children. We decided early on that wasn't good enough.",
      },
      {
        type: 'heading',
        text: 'The problem with FD&C dyes',
      },
      {
        type: 'text',
        text: "FD&C dyes (Food, Drug & Cosmetic certified synthetic colorants) have been the industry default for decades. They produce bright, consistent colors at low cost. But the European Food Safety Authority requires warning labels on foods containing six of them: \"May have an adverse effect on activity and attention in children.\" That label requirement alone tells you something.",
      },
      {
        type: 'heading',
        text: 'What we use instead',
      },
      {
        type: 'text',
        text: 'Every YumEarth color comes from real food sources: organic fruit and vegetable juice concentrates, turmeric, black carrot, purple sweet potato, annatto-free natural extracts. The red in our lollipops comes from fruit. The yellow comes from turmeric. It takes more work and costs more. We think that\'s worth it.',
      },
      {
        type: 'heading',
        text: 'Does it taste different?',
      },
      {
        type: 'text',
        text: "Yes, actually. When your color comes from real fruit, some of that flavor comes with it. Our strawberry lollipops taste like strawberries because strawberry is in the recipe, not just in the name on the label.",
      },
      {
        type: 'heading',
        text: 'Why this matters for retailers',
      },
      {
        type: 'text',
        text: "Parents read labels. In our experience, a parent who picks up a YumEarth product and reads the ingredient list almost always buys it. The ingredients are the pitch. No decoding required: if you can say it out loud without stumbling, it belongs in candy.",
      },
      {
        type: 'image',
        src: '/images/img/torg-logo.webp',
        alt: 'Torg',
      },
    ],
  },
];
---

<Layout title="Blog" description="YumEarth EU blog — organic food, sustainability, and the plant-based movement.">
  <Nav />
  <main class="pt-32">

    <section class="max-w-7xl mx-auto px-6 pb-16">
      <div class="max-w-2xl">
        <div class="badge mb-6" style="background:rgba(150,201,61,0.12); color:var(--color-green-dark);">
          Blog
        </div>
        <h1 class="mb-4" style="font-family:'Nunito',sans-serif; font-weight:900; font-size:clamp(2.5rem,6vw,4.5rem); line-height:0.95; letter-spacing:-0.03em; color:var(--color-ink);">
          good reads.<br />
          <span style="color:var(--color-teal);">better candy.</span>
        </h1>
        <p class="text-xl" style="color:var(--color-ink-muted); line-height:1.65;">
          Organic food, sustainability, health — and the occasional sweet obsession.
        </p>
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 pb-24">
      {posts.map(post => (
        <article class="max-w-3xl">
          <div class="mb-3 flex items-center gap-3">
            <span class="text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full"
              style="background:rgba(0,178,191,0.10); color:var(--color-teal);">
              {post.category}
            </span>
            {post.date && <span class="text-xs" style="color:var(--color-ink-muted);">{post.date}</span>}
          </div>

          <h2 class="font-black mb-8" style="font-family:'Nunito',sans-serif; font-weight:900; font-size:clamp(1.6rem,3vw,2.5rem); line-height:1.05; letter-spacing:-0.03em; color:var(--color-ink);">
            {post.title}
          </h2>

          <div class="space-y-5 text-base" style="color:var(--color-ink); line-height:1.75;">
            {post.body.map(block => (
              block.type === 'heading'
                ? <h3 class="font-black text-lg mt-8 mb-2" style="font-family:'Nunito',sans-serif; font-weight:900; letter-spacing:-0.02em;">{block.text}</h3>
                : block.type === 'intro'
                  ? <p class="text-xl font-medium" style="color:var(--color-ink-muted); line-height:1.65; max-width:65ch;">{block.text}</p>
                  : block.type === 'image'
                    ? <div class="mt-8 text-center"><img src={block.src} alt={block.alt} class="max-w-[180px] mx-auto block mb-3" /><p class="text-xs font-bold uppercase tracking-widest" style="color:var(--color-ink-muted);">Distributed through Torg</p></div>
                    : <p style="max-width:65ch;">{block.text}</p>
            ))}
          </div>

          <!-- CTA after article -->
          <div class="mt-16 rounded-3xl p-10" style="background:var(--color-surface);">
            <p class="text-xs font-black uppercase tracking-widest mb-3" style="color:var(--color-teal);">
              Organic & allergen-friendly
            </p>
            <h3 class="font-black mb-3" style="font-family:'Nunito',sans-serif; font-weight:900; font-size:clamp(1.5rem,3vw,2rem); letter-spacing:-0.03em;">
              YumEarth fits the movement.
            </h3>
            <p class="text-base mb-6" style="color:var(--color-ink-muted); line-height:1.65; max-width:480px;">
              USDA Organic certified. Vegan. Gluten-free. No artificial colors, no artificial flavors.
              Available across Europe, Middle East and beyond.
            </p>
            <div class="flex flex-wrap gap-3">
              <a href="/products" class="btn-primary text-sm">View products →</a>
              <a href="/contact" class="btn-secondary text-sm">Get in touch</a>
            </div>
          </div>
        </article>
      ))}
    </section>

  </main>
  <Footer />
</Layout>
