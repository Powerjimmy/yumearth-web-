---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import GlobeMap from '../components/react/GlobeMap';

function flag(iso: string) {
  return [...iso.toUpperCase()].map(c =>
    String.fromCodePoint(0x1F1E6 + c.charCodeAt(0) - 65)
  ).join("")
}

const europe = [
  { name: 'Albania',        iso: 'AL' },
  { name: 'Azerbaijan',     iso: 'AZ' },
  { name: 'Belgium',        iso: 'BE' },
  { name: 'Bulgaria',       iso: 'BG' },
  { name: 'Cyprus',         iso: 'CY' },
  { name: 'Czech Republic', iso: 'CZ' },
  { name: 'Denmark',        iso: 'DK' },
  { name: 'Estonia',        iso: 'EE' },
  { name: 'France',         iso: 'FR' },
  { name: 'Georgia',        iso: 'GE' },
  { name: 'Greece',         iso: 'GR' },
  { name: 'Ireland',        iso: 'IE' },
  { name: 'Iceland',        iso: 'IS' },
  { name: 'Kazakhstan',     iso: 'KZ' },
  { name: 'Kosovo',         iso: 'XK' },
  { name: 'Kyrgyzstan',     iso: 'KG' },
  { name: 'Latvia',         iso: 'LV' },
  { name: 'Lithuania',      iso: 'LT' },
  { name: 'Moldova',        iso: 'MD' },
  { name: 'Norway',         iso: 'NO' },
  { name: 'Poland',         iso: 'PL' },
  { name: 'Romania',        iso: 'RO' },
  { name: 'Russia',         iso: 'RU' },
  { name: 'Serbia',         iso: 'RS' },
  { name: 'Slovakia',       iso: 'SK' },
  { name: 'Spain',          iso: 'ES' },
  { name: 'Switzerland',    iso: 'CH' },
  { name: 'Ukraine',        iso: 'UA' },
  { name: 'Uzbekistan',     iso: 'UZ' },
];

const mena = [
  { name: 'Bahrain',      iso: 'BH' },
  { name: 'India',        iso: 'IN' },
  { name: 'Israel',       iso: 'IL' },
  { name: 'Ivory Coast',  iso: 'CI' },
  { name: 'Jordan',       iso: 'JO' },
  { name: 'Kuwait',       iso: 'KW' },
  { name: 'Lebanon',      iso: 'LB' },
  { name: 'Morocco',      iso: 'MA' },
  { name: 'Oman',         iso: 'OM' },
  { name: 'Qatar',        iso: 'QA' },
  { name: 'Saudi Arabia', iso: 'SA' },
  { name: 'UAE',          iso: 'AE' },
  { name: 'Vietnam',      iso: 'VN' },
  { name: 'South Africa', iso: 'ZA' },
];
---

<Layout title="Distribution" description="YumEarth EU — official EMEA distributor. Organic candy available in Spain, France, Belgium, Poland, UAE, Saudi Arabia and 30+ countries across Europe and the Middle East.">
  <Nav />
  <main class="pt-32">

    <section class="max-w-7xl mx-auto px-6 pb-20">
      <div class="max-w-2xl">
        <div class="badge mb-6" style="background:rgba(0,178,191,0.12); color:var(--color-teal);">
          Distribution
        </div>
        <h1 class="mb-4" style="font-family:'Nunito',sans-serif; font-weight:900; font-size:clamp(2.5rem,6vw,4.5rem); line-height:0.95; letter-spacing:-0.03em; color:var(--color-ink);">
          Official YumEarth EMEA Distributor
        </h1>
        <p class="text-lg mt-6" style="color:var(--color-ink-muted); line-height:1.7; max-width:580px;">
          YumEarth EU is the official EMEA master distributor for YumEarth organic candy. We supply retailers, distributors and specialty food stores across Europe, the Middle East and Central Asia — from Spain and France to the UAE, Saudi Arabia and Kazakhstan. If you're looking for YumEarth in Europe or the Middle East, you're in the right place.
        </p>
      </div>
    </section>

    <section class="max-w-5xl mx-auto pb-16">
      <GlobeMap client:visible />
    </section>

    <!-- Europe -->
    <section class="py-16" style="background:var(--color-surface);">
      <div class="max-w-7xl mx-auto px-6">
        <div class="flex items-center gap-3 mb-8">
          <span class="text-3xl">🇪🇺</span>
          <h2 class="text-2xl" style="font-family:'Nunito',sans-serif; font-weight:900;">Europe</h2>
        </div>
        <div class="flex flex-wrap gap-3">
          {europe.map(({ name, iso }) => (
            <span
              class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-bold"
              style="background:white; color:var(--color-ink);"
            >
              <span aria-hidden="true">{flag(iso)}</span>{name}
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- MENA -->
    <section class="py-16" style="background:var(--color-cream);">
      <div class="max-w-7xl mx-auto px-6">
        <div class="flex items-center gap-3 mb-8">
          <span class="text-3xl">🌍</span>
          <h2 class="text-2xl" style="font-family:'Nunito',sans-serif; font-weight:900;">Middle East & Other Territories</h2>
        </div>
        <div class="flex flex-wrap gap-3">
          {mena.map(({ name, iso }) => (
            <span
              class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-bold"
              style="background:white; color:var(--color-ink); border:1px solid rgba(0,0,0,0.06);"
            >
              <span aria-hidden="true">{flag(iso)}</span>{name}
            </span>
          ))}
        </div>
      </div>
    </section>


  </main>
  <Footer />
</Layout>
