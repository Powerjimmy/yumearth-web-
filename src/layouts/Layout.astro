---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Friendly Sweets, Yummy Treats. YumEarth organic candy is vegan, allergen friendly, gluten free, non-GMO and free from artificial dyes and flavours.',
  ogImage = '/images/og-default.jpg'
} = Astro.props;

const siteUrl = 'https://yumearth.eu';
const fullTitle = title === 'YumEarth EU' ? title : `${title} | YumEarth EU`;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#00B2BF" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${siteUrl}${Astro.url.pathname}`} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${Astro.url.origin}${ogImage}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${Astro.url.origin}${ogImage}`} />
    {Astro.url.hostname.endsWith('vercel.app') && <meta name="robots" content="noindex" />}

    <!-- ClashDisplay (headlines) + Satoshi (body) via Fontshare -->
    <link rel="preconnect" href="https://api.fontshare.com" />
    <link
      href="https://api.fontshare.com/v2/css?f[]=clash-display@600,700&f[]=satoshi@400,500,700&display=swap"
      rel="stylesheet"
    />
    <!-- Nunito fallback -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito:wght@700;800;900&display=swap"
      rel="stylesheet"
    />


    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="canonical" href={`${siteUrl}${Astro.url.pathname.replace(/\/$/, '') || '/'}`} />
    <title>{fullTitle}</title>
    <ClientRouter />

    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-NS1X4PNQTW"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-NS1X4PNQTW');
    </script>

    <!-- JSON-LD: Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "YumEarth EU",
      "url": "https://yumearth.eu",
      "logo": "https://yumearth.eu/images/yumearth-logo.png",
      "description": "EMEA Master Distribution of YumEarth organic candy. No artificial colors, no artificial flavors.",
      "areaServed": "Europe",
      "sameAs": ["https://www.instagram.com/yumearth.eu/"],
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "hello@yumearth.eu",
        "contactType": "customer service"
      }
    })} />
  </head>
  <body style="font-family:'Satoshi','Nunito',sans-serif; overflow-x:hidden;">
    <!-- Global background blobs — above content, below nav, multiply blend -->
    <div aria-hidden="true" style="position:fixed;inset:0;pointer-events:none;z-index:40;overflow:hidden;mix-blend-mode:multiply;">
      <div style="position:absolute;left:-200px;top:10%;width:700px;height:700px;border-radius:50%;background:radial-gradient(circle,rgba(0,178,191,0.16) 0%,transparent 65%);animation:blob-drift-a 20s ease-in-out infinite;"></div>
      <div style="position:absolute;right:-150px;top:35%;width:650px;height:650px;border-radius:50%;background:radial-gradient(circle,rgba(150,201,61,0.13) 0%,transparent 65%);animation:blob-drift-b 24s ease-in-out infinite;"></div>
      <div style="position:absolute;left:20%;bottom:-100px;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(196,91,174,0.11) 0%,transparent 65%);animation:blob-drift-c 28s ease-in-out infinite;"></div>
    </div>
    <div>
      <slot />
    </div>
    <Analytics />
  </body>
</html>
