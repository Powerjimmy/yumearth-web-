---
// Lead capture form — posts to /api/contact
// Resend handles email delivery
---

<section id="contact-form" class="py-24" style="background: var(--color-surface);">
  <div class="max-w-2xl mx-auto px-6 text-center">
    <span
      class="inline-block text-sm font-semibold uppercase tracking-widest mb-4 px-4 py-1.5 rounded-full"
      style="background: rgba(146,196,59,0.15); color: var(--color-green-dark);"
    >
      Work with us
    </span>
    <h2 class="text-display text-4xl md:text-5xl mb-4" style="font-family:'ClashDisplay',sans-serif;">
      Interested in distributing?
    </h2>
    <p class="text-ink-muted mb-10 text-lg">
      Tell us about your project. Distributors, retailers, online stores — let's talk.
    </p>

    <form
      id="lead-form"
      class="text-left space-y-5"
      novalidate
    >
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <label for="name" class="block text-sm font-medium mb-1.5">Name *</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            placeholder="Your name"
            class="w-full px-4 py-3 rounded-2xl border border-ink/10 bg-white focus:outline-none focus:ring-2 focus:border-transparent transition-all text-sm"
          />
        </div>
        <div>
          <label for="company" class="block text-sm font-medium mb-1.5">Company</label>
          <input
            type="text"
            id="company"
            name="company"
            placeholder="Your company"
            class="w-full px-4 py-3 rounded-2xl border border-ink/10 bg-white focus:outline-none focus:ring-2 focus:border-transparent transition-all text-sm"
          />
        </div>
      </div>

      <div>
        <label for="email" class="block text-sm font-medium mb-1.5">Email *</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          placeholder="you@company.com"
          class="w-full px-4 py-3 rounded-2xl border border-ink/10 bg-white focus:outline-none focus:ring-2 focus:border-transparent transition-all text-sm"
        />
      </div>

      <div>
        <label for="message" class="block text-sm font-medium mb-1.5">Message *</label>
        <textarea
          id="message"
          name="message"
          required
          rows="4"
          placeholder="Tell us about your project..."
          class="w-full px-4 py-3 rounded-2xl border border-ink/10 bg-white focus:outline-none focus:ring-2 focus:border-transparent transition-all text-sm resize-none"
        ></textarea>
      </div>

      <!-- Honeypot anti-spam -->
      <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" />

      <button
        type="submit"
        id="form-submit"
        class="btn-primary w-full justify-center text-base"
      >
        Send message
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M2 8l12 0M8 2l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <!-- Status messages -->
      <div id="form-success" class="hidden text-center py-3 px-4 rounded-2xl text-sm font-medium" style="background:rgba(146,196,59,0.15); color:var(--color-green-dark);">
        Message received. We'll be in touch shortly.
      </div>
      <div id="form-error" class="hidden text-center py-3 px-4 rounded-2xl text-sm font-medium" style="background:rgba(255,61,0,0.1); color:var(--color-orange);">
        Error sending. Try again or write to us at hello@yumearth.eu
      </div>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById('lead-form') as HTMLFormElement;
  const btn = document.getElementById('form-submit') as HTMLButtonElement;
  const successEl = document.getElementById('form-success')!;
  const errorEl = document.getElementById('form-error')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Honeypot check
    const honeypot = (form.elements.namedItem('website') as HTMLInputElement)?.value;
    if (honeypot) return;

    btn.textContent = 'Sending...';
    btn.setAttribute('disabled', '');

    const data = Object.fromEntries(new FormData(form));

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        form.reset();
        successEl.classList.remove('hidden');
        errorEl.classList.add('hidden');
      } else {
        throw new Error('Server error');
      }
    } catch {
      errorEl.classList.remove('hidden');
      successEl.classList.add('hidden');
    } finally {
      btn.textContent = 'Send message';
      btn.removeAttribute('disabled');
    }
  });
</script>
