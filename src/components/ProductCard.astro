---
interface Props {
  name: string;
  description: string;
  color: string;
  emoji: string;
  image?: string;
  href?: string;
}

const { name, description, color, emoji, image, href = '/productos' } = Astro.props;
---

<a
  href={href}
  class="card-lift group block rounded-3xl overflow-hidden relative"
  style={`background: ${color};`}
>
  <div class="p-8 pb-0 min-h-[280px] flex flex-col">
    <div class="flex-1">
      <h3 class="text-display text-2xl text-ink mb-2" style="font-family:'ClashDisplay',sans-serif;">
        {name}
      </h3>
      <p class="text-sm text-ink/70 max-w-[200px] leading-relaxed">{description}</p>
    </div>

    <!-- Product image -->
    <div class="mt-4 flex justify-end">
      {image ? (
        <img
          src={image}
          alt={name}
          class="w-40 h-40 object-contain drop-shadow-lg group-hover:scale-110 transition-transform duration-300"
        />
      ) : (
        <span class="text-7xl group-hover:scale-110 transition-transform duration-300 block">
          {emoji}
        </span>
      )}
    </div>
  </div>

  <!-- Arrow indicator -->
  <div class="absolute top-6 right-6 w-10 h-10 rounded-full bg-white/30 flex items-center justify-center group-hover:bg-white/60 transition-colors duration-200">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
      <path d="M3 8h10m-4-4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
</a>
