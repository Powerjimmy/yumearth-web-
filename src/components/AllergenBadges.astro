      <path d="M26 20l-4-4M26 20l4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      <path d="M26 25l-4-4M26 25l4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      <path d="M26 30l-4-4M26 30l4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
    </svg>`,
  },
  {
    label: 'SHELLFISH\nFREE',
    svg: `<svg viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg" width="52" height="52">
      <circle cx="26" cy="26" r="23" stroke="currentColor" stroke-width="2.5"/>
      <line x1="38" y1="11" x2="14" y2="41" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
      <path d="M26 34c0 0-9-4-9-12 0-4 4-8 9-8s9 4 9 8c0 8-9 12-9 12z" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linejoin="round"/>
      <path d="M22 36l-2 3M26 37v3M30 36l2 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
    </svg>`,
  },
  {
    label: 'FISH\nFREE',
    svg: `<svg viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg" width="52" height="52">
      <circle cx="26" cy="26" r="23" stroke="currentColor" stroke-width="2.5"/>
      <line x1="38" y1="11" x2="14" y2="41" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
      <path d="M15 26c3-5 7-9 13-9s9 4 9 9-3 9-9 9-10-4-13-9z" stroke="currentColor" stroke-width="1.8" fill="none"/>
      <path d="M37 20l4-4M37 32l4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      <circle cx="34" cy="23" r="1.5" fill="currentColor"/>
    </svg>`,
  },
];
---

<section class="py-8" style="background:white;">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex items-center justify-center gap-3 md:gap-5 flex-wrap md:flex-nowrap">

      <!-- Left 4 icons -->
      {icons.slice(0, 4).map(icon => (
        <div class="flex flex-col items-center gap-1 w-12 md:w-14 flex-shrink-0" style={`color:${teal}`}>
          <div set:html={icon.svg} class="w-10 h-10 md:w-12 md:h-12" />
          <p class="text-[8px] md:text-[9px] font-black uppercase tracking-wider text-center leading-tight whitespace-pre-line"
            style={`color:${teal}`}>{icon.label}</p>
        </div>
      ))}

      <!-- Center allergy friendly badge -->
      <div class="flex-shrink-0 mx-1 md:mx-3">
        <div class="w-16 h-16 md:w-20 md:h-20 rounded-full flex flex-col items-center justify-center relative overflow-hidden"
          style="border: 3px solid var(--color-teal);">
          <!-- Outer ring green top -->
          <div class="absolute inset-0 rounded-full flex flex-col items-center justify-center"
            style="background: linear-gradient(180deg, #5a9400 0%, #5a9400 30%, white 30%);">
            <p class="text-[7px] font-black uppercase tracking-widest text-white mt-0.5">No Artificial</p>
          </div>
          <!-- Inner content -->
          <div class="relative z-10 flex flex-col items-center justify-center mt-3">
            <p class="text-[8px] font-black italic" style="color:var(--color-teal);">allergy friendly</p>
            <p class="text-sm md:text-base font-black uppercase leading-none" style="color:var(--color-teal);">DYES</p>
          </div>
        </div>
      </div>

      <!-- Right 5 icons -->
      {icons.slice(4).map(icon => (
        <div class="flex flex-col items-center gap-1 w-12 md:w-14 flex-shrink-0" style={`color:${teal}`}>
          <div set:html={icon.svg} class="w-10 h-10 md:w-12 md:h-12" />
          <p class="text-[8px] md:text-[9px] font-black uppercase tracking-wider text-center leading-tight whitespace-pre-line"
            style={`color:${teal}`}>{icon.label}</p>
        </div>
      ))}

    </div>
  </div>
</section>
