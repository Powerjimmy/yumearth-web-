      <circle cx="26" cy="26" r="23" stroke="currentColor" stroke-width="2.5"/>
      <line x1="38" y1="11" x2="14" y2="41" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
      <path d="M20 22c0-3.3 2.7-6 6-6s6 2.7 6 6c0 1.8-.8 3.4-2 4.5 1.2 1.1 2 2.7 2 4.5 0 3.3-2.7 6-6 6s-6-2.7-6-6c0-1.8.8-3.4 2-4.5C20.8 25.4 20 23.8 20 22z" stroke="currentColor" stroke-width="1.8" fill="none"/>
    </svg>`,
  },
  {
    label: 'TREE NUT\nFREE',
    svg: `<svg viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg" width="52" height="52">
      <circle cx="26" cy="26" r="23" stroke="currentColor" stroke-width="2.5"/>
      <line x1="38" y1="11" x2="14" y2="41" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
      <path d="M26 38V28" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      <path d="M26 28C26 28 18 24 18 17a8 8 0 0 1 16 0c0 7-8 11-8 11z" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linejoin="round"/>
    </svg>`,
  },
  {
    label: 'SOY\nFREE',
    svg: `<svg viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg" width="52" height="52">
      <circle cx="26" cy="26" r="23" stroke="currentColor" stroke-width="2.5"/>
      <line x1="38" y1="11" x2="14" y2="41" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
      <ellipse cx="26" cy="26" rx="8" ry="11" stroke="currentColor" stroke-width="1.8" fill="none"/>
      <path d="M18 26c3-3 5-5 8-5s5 2 8 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" fill="none"/>
    </svg>`,
  },
  {
    label: 'DAIRY\nFREE',
    svg: `<svg viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg" width="52" height="52">
      <circle cx="26" cy="26" r="23" stroke="currentColor" stroke-width="2.5"/>
      <line x1="38" y1="11" x2="14" y2="41" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
      <path d="M20 18h12l1 4v14H19V22l1-4z" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linejoin="round"/>
      <path d="M23 18v-3h6v3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
    </svg>`,
  },
  {
    label: 'SESAME\nFREE',
    svg: `<svg viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg" width="52" height="52">
      <circle cx="26" cy="26" r="23" stroke="currentColor" stroke-width="2.5"/>
      <line x1="38" y1="11" x2="14" y2="41" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
      <ellipse cx="22" cy="21" rx="3.5" ry="5.5" stroke="currentColor" stroke-width="1.8" fill="none"/>
      <ellipse cx="30" cy="21" rx="3.5" ry="5.5" stroke="currentColor" stroke-width="1.8" fill="none"/>
      <ellipse cx="26" cy="31" rx="3.5" ry="5.5" stroke="currentColor" stroke-width="1.8" fill="none"/>
    </svg>`,
  },
  {
    label: 'EGG\nFREE',
    svg: `<svg viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg" width="52" height="52">
      <circle cx="26" cy="26" r="23" stroke="currentColor" stroke-width="2.5"/>
      <line x1="38" y1="11" x2="14" y2="41" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
      <path d="M26 14c-6 0-10 5.5-10 12 0 5.5 4.5 10 10 10s10-4.5 10-10c0-6.5-4-12-10-12z" stroke="currentColor" stroke-width="1.8" fill="none"/>
    </svg>`,
  },
  {
    label: 'GLUTEN\nFREE',
    svg: `<svg viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg" width="52" height="52">
