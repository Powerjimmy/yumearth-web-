---
const year = new Date().getFullYear();
---

<footer style="background:var(--color-dark); color:white;">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="md:col-span-2">
        <a href="/" class="inline-block mb-4">
          <span class="text-3xl font-black" style="font-family:'Nunito',sans-serif; color:var(--color-teal);">
            yum<span style="color:var(--color-green);">earth</span>
            <span class="text-xs font-bold ml-1 px-1.5 py-0.5 rounded align-middle" style="background:var(--color-teal); font-size:10px;">EU</span>
          </span>
        </a>
        <p class="text-sm max-w-xs leading-relaxed" style="color:rgba(255,255,255,0.5);">
          Organic, simple, natural candies made with much love and few (if any) allergens.
          EMEA Master Distribution.
        </p>
        <p class="text-xs mt-3 font-bold" style="color:rgba(255,255,255,0.3);">
          Gurux Entertainment S.L · info@yumearth.eu
        </p>
        <div class="flex gap-4 mt-6">
          <a
            href="https://www.instagram.com/yumearth.eu/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="transition-opacity"
            style="opacity:0.5;"
            onmouseover="this.style.opacity='1'"
            onmouseout="this.style.opacity='0.5'"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
          <a
            href="https://www.facebook.com/yumearth.eu"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="transition-opacity"
            style="opacity:0.5;"
            onmouseover="this.style.opacity='1'"
            onmouseout="this.style.opacity='0.5'"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="text-xs font-bold uppercase tracking-widest mb-4" style="color:rgba(255,255,255,0.35);">Navigation</h4>
        <ul class="space-y-3 text-sm" style="color:rgba(255,255,255,0.6);">
          <li><a href="/products" class="hover:text-white transition-colors">Products</a></li>
          <li><a href="/distribution" class="hover:text-white transition-colors">Distribution</a></li>
          <li><a href="/blog" class="hover:text-white transition-colors">Blog</a></li>
          <li><a href="/contact" class="hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-xs font-bold uppercase tracking-widest mb-4" style="color:rgba(255,255,255,0.35);">Info</h4>
        <ul class="space-y-3 text-sm" style="color:rgba(255,255,255,0.6);">
          <li><a href="https://yumearthhelp.zendesk.com" target="_blank" rel="noopener" class="hover:text-white transition-colors">FAQ & Allergens</a></li>
          <li><a href="mailto:info@yumearth.eu" class="hover:text-white transition-colors">info@yumearth.eu</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t mt-12 pt-6 flex flex-col md:flex-row items-center justify-between gap-3 text-xs" style="border-color:rgba(255,255,255,0.08); color:rgba(255,255,255,0.3);">
      <span>© {year} YumEarth EU · Gurux Entertainment S.L. All rights reserved.</span>
      <span>EMEA Master Distribution of YumEarth®</span>
    </div>
  </div>
</footer>
