---
interface Props {
  topColor?: string;
  bottomColor?: string;
  flip?: boolean;
}
const { topColor = '#FDFCF8', bottomColor = '#F4F9F0', flip = false } = Astro.props;
---

<div
  class="wave-divider"
  style={`background:${topColor}; margin-bottom:-2px;`}
  aria-hidden="true"
>
  <svg
    viewBox="0 0 1440 80"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    preserveAspectRatio="none"
    style={`display:block; width:100%; height:80px; ${flip ? 'transform:scaleY(-1);' : ''}`}
  >
    <path
      d="M0,40 C240,80 480,0 720,40 C960,80 1200,0 1440,40 L1440,80 L0,80 Z"
      fill={bottomColor}
    />
  </svg>
</div>
