---
const navLinks: { href: string; label: string; external?: boolean }[] = [
  { href: '/products', label: 'Products' },
  { href: '/distribution', label: 'Distribution' },
  { href: '/faqs', label: 'FAQs' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<nav id="nav" class="fixed top-0 left-0 right-0 z-50" style="background:#ffffff; transition: background 200ms var(--ease-out, cubic-bezier(0.23,1,0.32,1)), box-shadow 200ms var(--ease-out, cubic-bezier(0.23,1,0.32,1))">
  <!-- Announcement bar -->
  <div id="announcement-bar" class="w-full py-2 text-center text-xs font-black tracking-wider transition-all duration-300 px-4" style="background:var(--color-green); color:white;">
    Organic · Allergy-friendly · No Artificial Dyes<span class="hidden sm:inline"> · EMEA Master Distribution</span>
  </div>

  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group">
      <img
        src="/images/yumearth-logo.png"
        alt="YumEarth EU"
        width="200" height="86"
        class="h-14 w-auto"
        onerror="this.style.display='none'; document.getElementById('logo-text').style.display='flex'"
      />
      <span id="logo-text" class="hidden items-center gap-1">
        <span class="text-2xl font-black" style="font-family:'Nunito',sans-serif; color:var(--color-teal); letter-spacing:-0.03em;">
          yum<span style="color:var(--color-green);">earth</span>
        </span>
        <span class="text-[9px] font-black px-1.5 py-0.5 rounded text-white" style="background:var(--color-teal);">EU</span>
      </span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <li class={link.href === '/products' ? 'nav-has-dropdown relative' : ''}>
          <a
            href={link.href}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
            class:list={[
              'text-sm font-black transition-colors duration-150 flex items-center gap-1',
              !link.external && (currentPath === link.href || currentPath.startsWith(link.href + '/'))
                ? 'text-teal'
                : 'text-ink hover:text-teal'
            ]}
            style="font-family:'Satoshi',sans-serif;"
          >
            {link.label}
            {link.href === '/products' && (
              <svg width="10" height="10" viewBox="0 0 10 10" fill="currentColor" class="nav-chevron" aria-hidden="true">
                <path d="M1 3l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
          </a>

          {link.href === '/products' && (
            <div class="nav-dropdown absolute top-full left-1/2 pt-3" style="transform:translateX(-50%);">
              <div class="rounded-2xl overflow-hidden py-2" style="background:white; box-shadow:0 8px 32px rgba(0,0,0,0.12); border:1px solid rgba(0,0,0,0.06); min-width:180px; transform-origin:top center;">
                <a href="/lollipops" class="nav-dd-item flex items-center gap-3 px-5 py-3 text-sm font-bold transition-colors"
                  style={`color:${currentPath.startsWith('/lollipops') ? 'var(--color-lollipop)' : 'var(--color-ink)'};`}>
                  <span class="w-2 h-2 rounded-full flex-shrink-0" style="background:var(--color-lollipop);"></span>
                  Lollipops
                </a>
                <a href="/soft-candy" class="nav-dd-item flex items-center gap-3 px-5 py-3 text-sm font-bold transition-colors"
                  style={`color:${currentPath.startsWith('/soft-candy') ? 'var(--color-green)' : 'var(--color-ink)'};`}>
                  <span class="w-2 h-2 rounded-full flex-shrink-0" style="background:var(--color-green);"></span>
                  Soft Candy
                </a>
              </div>
            </div>
          )}
        </li>
      ))}
    </ul>

    <!-- Desktop CTA + Instagram icon -->
    <div class="hidden md:flex items-center gap-4">
      <a href="https://www.instagram.com/yumearth.eu/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="transition-opacity opacity-50 hover:opacity-100">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
        </svg>
      </a>
      <a href="https://www.facebook.com/yumearth.eu" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="transition-opacity opacity-50 hover:opacity-100">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
      </a>
      <a href="https://www.linkedin.com/company/yumearth-europe-by-gurux/posts/?feedView=all" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="transition-opacity opacity-50 hover:opacity-100">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <a href="/contact" class="btn-primary text-sm">
        Get in touch
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button id="menu-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu" class="md:hidden flex flex-col gap-[5px] p-3" style="min-width:44px; min-height:44px; justify-content:center; align-items:center;">
      <span class="block w-7 h-[2.5px] rounded-full" style="background:var(--color-ink); transition:transform 200ms cubic-bezier(0.23,1,0.32,1), opacity 200ms cubic-bezier(0.23,1,0.32,1);" id="bar1"></span>
      <span class="block w-7 h-[2.5px] rounded-full" style="background:var(--color-ink); transition:transform 200ms cubic-bezier(0.23,1,0.32,1), opacity 200ms cubic-bezier(0.23,1,0.32,1);" id="bar2"></span>
      <span class="block w-7 h-[2.5px] rounded-full" style="background:var(--color-ink); transition:transform 200ms cubic-bezier(0.23,1,0.32,1), opacity 200ms cubic-bezier(0.23,1,0.32,1);" id="bar3"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden px-6 flex flex-col gap-5"
    style="background:var(--color-cream); border-top:1px solid rgba(0,0,0,0.06); opacity:0; max-height:0; overflow:hidden; padding-top:0; padding-bottom:0; transition:opacity 200ms cubic-bezier(0.23,1,0.32,1), max-height 220ms cubic-bezier(0.23,1,0.32,1), padding 200ms cubic-bezier(0.23,1,0.32,1);"
  >
    {navLinks.map(link => (
      link.href === '/products' ? (
        <div class="flex flex-col gap-1">
          <a
            href="/products"
            class="text-lg font-black text-ink hover:text-teal transition-colors"
            style="font-family:'Satoshi',sans-serif;"
          >
            Products
          </a>
          <div class="flex flex-col gap-1 pl-4 border-l-2" style="border-color:rgba(0,0,0,0.08);">
            <a href="/lollipops" class="text-base font-bold transition-colors hover:text-teal" style="color:var(--color-lollipop); font-family:'Satoshi',sans-serif;">
              Lollipops
            </a>
            <a href="/soft-candy" class="text-base font-bold transition-colors hover:text-teal" style="color:var(--color-green); font-family:'Satoshi',sans-serif;">
              Soft Candy
            </a>
          </div>
        </div>
      ) : (
        <a
          href={link.href}
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noopener noreferrer' : undefined}
          class="text-lg font-black text-ink hover:text-teal transition-colors"
          style="font-family:'Satoshi',sans-serif;"
        >
          {link.label}
        </a>
      )
    ))}
    <a href="/contact" class="btn-primary text-sm mt-2">Get in touch</a>
  </div>
</nav>

<script>
  function initNav() {
    const nav = document.getElementById('nav');
    const toggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const bar1 = document.getElementById('bar1');
    const bar2 = document.getElementById('bar2');
    const bar3 = document.getElementById('bar3');
    const announcementBar = document.getElementById('announcement-bar');

    if (!nav || !toggle || !mobileMenu || !bar1 || !bar2 || !bar3) return;

    // Reset mobile menu state on page change
    let open = false;
    mobileMenu.style.opacity = '0';
    mobileMenu.style.maxHeight = '0';
    mobileMenu.style.paddingTop = '0';
    mobileMenu.style.paddingBottom = '0';
    bar1.style.transform = '';
    bar2.style.opacity = '1';
    bar3.style.transform = '';

    let scrolled = false;
    const onScroll = () => {
      const past = window.scrollY > 40;
      if (past === scrolled) return;
      scrolled = past;
      nav.style.background = '#ffffff';
      nav.style.backdropFilter = 'none';
      nav.style.boxShadow = past ? '0 1px 0 rgba(0,0,0,0.06)' : 'none';
      if (announcementBar) {
        announcementBar.classList.toggle('announcement-collapsed', past);
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });

    const onToggle = () => {
      open = !open;
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      if (open) {
        mobileMenu.style.opacity = '1';
        mobileMenu.style.maxHeight = '480px';
        mobileMenu.style.paddingTop = '1.5rem';
        mobileMenu.style.paddingBottom = '1.5rem';
      } else {
        mobileMenu.style.opacity = '0';
        mobileMenu.style.maxHeight = '0';
        mobileMenu.style.paddingTop = '0';
        mobileMenu.style.paddingBottom = '0';
      }
      bar1.style.transform = open ? 'translateY(8px) rotate(45deg)' : '';
      bar2.style.opacity = open ? '0' : '1';
      bar3.style.transform = open ? 'translateY(-8px) rotate(-45deg)' : '';
    };
    toggle.addEventListener('click', onToggle);

    // Cleanup on next transition
    document.addEventListener('astro:before-swap', () => {
      window.removeEventListener('scroll', onScroll);
      toggle.removeEventListener('click', onToggle);
    }, { once: true });
  }

  // Run on initial load and after every Astro page transition
  document.addEventListener('astro:page-load', initNav);
</script>

<style>
  /* Announcement bar collapse */
  #announcement-bar {
    overflow: hidden;
    max-height: 40px;
    transition: max-height 200ms cubic-bezier(0.23,1,0.32,1), padding 200ms cubic-bezier(0.23,1,0.32,1), opacity 200ms cubic-bezier(0.23,1,0.32,1);
  }
  #announcement-bar.announcement-collapsed {
    max-height: 0;
    padding-top: 0;
    padding-bottom: 0;
    opacity: 0;
  }

  /* Products dropdown */
  .nav-dropdown {
    opacity: 0;
    pointer-events: none;
    transform: translateX(-50%) translateY(-6px);
    transition: opacity 180ms cubic-bezier(0.23,1,0.32,1), transform 180ms cubic-bezier(0.23,1,0.32,1);
  }
  .nav-has-dropdown:focus-within .nav-dropdown {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }
  .nav-chevron {
    transition: transform 180ms cubic-bezier(0.23,1,0.32,1);
  }
  .nav-has-dropdown:focus-within .nav-chevron {
    transform: rotate(180deg);
  }
  @media (hover: hover) and (pointer: fine) {
    .nav-has-dropdown:hover .nav-dropdown {
      opacity: 1;
      pointer-events: auto;
      transform: translateX(-50%) translateY(0);
    }
    .nav-has-dropdown:hover .nav-chevron {
      transform: rotate(180deg);
    }
    .nav-dd-item:hover {
      background: rgba(0,0,0,0.04);
      color: var(--color-teal) !important;
    }
  }
</style>
